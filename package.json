    "cli-progress": "^3.12.0",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  },
  "scripts": {
    "start": "node dist/index.js",
    "start:bg": "nohup node dist/index.js > mcp.log 2>&1 &"
  }
