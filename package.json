{
  "name": "gemini-mcp-code-analyzer",
  "version": "1.0.0",
  "description": "Advanced Code Analyzer with AST Reduction and Gemini",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
