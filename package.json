{
  "name": "gemini-mcp-code-analyzer",
  "version": "1.0.0",
  "description": "Advanced Code Analyzer with AST Reduction and Gemini",
  "main": "src/indexer/index.ts",
  "type": "module",
  "scripts": {
    "prewarm": "NODE_OPTIONS=\"--max-old-space-size=8192\" npx tsx src/indexer/index.ts --prewarm",
    "start": "NODE_OPTIONS=\"--max-old-space-size=8192\" npx tsx src/indexer/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/indexer/index.ts",
    "gemini": "gemini",
    "gemini:pro": "gemini --model gemini-2.5-pro"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "cli-progress": "^3.12.0",
    "dotenv": "^17.3.1",
    "fuzzysort": "^3.1.0",
    "glob": "^13.0.6",
    "graphology": "^0.26.0",
    "graphology-metrics": "^2.4.0",
    "pdfkit": "^0.17.2",
    "strip-ansi": "^7.2.0",
    "ts-morph": "^21.0.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.11.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
